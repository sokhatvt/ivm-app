<div id="groupSet"class="groupBox"><div><b>Currency</b></div><div class="groupVal"><div>Symbol<input id="nChar"onchange="W8()"type="number"min=1 max=4 style="width: 70px;"></div><div id="symbol"class="arrChr"></div><div>Rate</div><div id="rate"class="arrChr"></div><div>Decimal</div><div id="decimal"class="arrChr"></div></div><div><b>Invoice Information</b></div><div class="groupVal printObj"><div class="company"><input type="checkbox"class="company">Header</div><input id="head"type="text"placeholder="Name"value="<%= obj.inf.head %>"onchange="S1(this)"><div class="companyInf"><input type="checkbox"class="companyInf">Footer</div><input id="foot"type="text"placeholder="Information"value="<%= obj.inf.foot%>"onchange="S1(this)"><div class="totalInf"><input type="checkbox"class="totalInf">Total</div><input id="total"type="text"value="<%= obj.inf.total %>"onchange="S1(this)"></div><div><b>Print Column</b></div><ul id="printCol"class="printObj"><li><input class="cNo"type="checkbox">nNo</li><li><input class="cBar"type="checkbox">Barcode</li><li><input class="cDes"type="checkbox"checked onclick="return false;">Des...</li><li><input class="cUnit"type="checkbox">Unit</li><li><input class="cQty"type="checkbox"checked onclick="return false;">Qty</li><li><input class="cPrice"type="checkbox">Price/cost</li><li><input class="cAmo"type="checkbox"checked onclick="return false;">Amount</li><li><input class="cChr"type="checkbox"checked onclick="return false;">$$</li></ul><div><b>Lock Date</b></div><div class="groupVal"><div>Lock to</div><input id="lockTo"type="date"value=<%=obj.lockTo%>></div><button id='btnSave'type='button'onclick='U2()'disabled>Save</button><datalist id="listChr"><option value="$"></option><option value="฿"></option><option value="៛"></option><option value="₫"></option><option value="€"></option><option value="¥"></option><option value="₩"></option></datalist></div>