<!DOCTYPE html><html lang="en"dir="ltr"><head><meta charset="utf-8"><title><%= obj.title %></title><link rel="stylesheet"type="text/css"href="/css/cvs.css?v=<%- obj.ver %>"><link rel="stylesheet"type="text/css"href="/css/auto.css?v=<%- obj.ver %>"></head><body><div class="screen"><%- include(obj.strBar, {...obj}) %><div id="inBox"><div><div class="groupBox"><label>Code</label><input id="code"name="<%= obj.tblname %>"type="text"placeholder="<%= obj.title %>"data-trimtext="1"><label>Full Name</label><div class="inlineGrid"><span><input id="fname"type="text"><div class="smallChar">First Name</div></span><span><input id="lname"type="text"><div class="smallChar">Last Name</div></span></div><label>Area / Group</label><input id="des"type="text"></div><div class="groupBox"><label>Location</label><div id="addLoc"onclick="D10()"class="btn classGreen">Add</div><div class="inlineGrid"><span><div id="locPos"></div><div class="smallChar">Position</div></span><span><div id="locDes"></div><div class="smallChar">Description</div></span></div></div><div class="groupBox boxParent"><a class="delImg btn"onclick="B6(this)">X</a><img id="showImg"class="showImg"data-noS=1><input id="getImg"class="noSave"type="file"onchange="M5()"accept=".jpeg,.jpg,.png,.bmp,.tiff,.gif"data-noS=1></div><div class="groupBox"><label>Phone Number</label><input id="phone"type="text"><label>Email</label><input id="email"type="text"><% if(obj.tblname != "stf"){ %><label>TelegramID</label><input id="telgr"type="text"><%}%><label>Facebook</label><input id="fbook"type="text"></div><div class="groupBox"><label>Address</label><div><input id="str"type="text"><div class="smallChar">Street Address</div></div><div><input id="str2"type="text"><div class="smallChar">Street Address Line 2</div></div><div class="inlineGrid"><span><input id="city"type="text"><div class="smallChar">City</div></span><span><input id="state"type="text"><div class="smallChar">State / Province</div></span></div><div><input id="zip"type="text"><div class="smallChar">Postal / Zip Code</div></div></div><div class="groupBox"><% if(obj.tblname == "cus" || obj.tblname == "sup"){ %><label>Company / Agency Name</label><% }else{ %><label>Position</label><% } %><input id="cpan"type="text"><label>Note</label><textarea id="note"rows="4"cols="50"onchange="Y('save')"></textarea></div></div></div></div><input id="id"type="hidden"value=0 data-def=0 data-noS=1><input type="hidden"id="ids"><script type="text/javascript">const keyID = ["id", "ids", "code", "fname", "lname", "des", "getImg", "str", "str2", "city", "state", "zip", "phone", "email", "telgr", "fbook", "cpan", "note" ]; const tblname = "<%= obj.tblname %>"; const J = "cvs";</script><script type="text/javascript"src="/js/auto.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/pcv.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/domtoimage.js?v=<%- obj.ver %>"></script></body></html>