<!DOCTYPE html><html lang="en"dir="ltr"><head><meta charset="utf-8"><title>Product</title><link rel="stylesheet"type="text/css"href="/css/auto.css?v=<%- obj.ver %>"><link rel="stylesheet"type="text/css"href="/css/pro.css?v=<%- obj.ver %>"></head><body><div class="screen"><%- include(obj.strBar, {...obj}) %><div id="inBox"><div><div id="spaceTop"></div><%- include('./extList.ejs') %><div class="group"><div>Code</div><input id="code"name="pro"type="text"data-trimtext="1"><div>Barcode<a class="cam"onclick="W6('cam')"></a></div><input id="bcode"name="pro"data-listtype='Q5'type="text"data-trimtext="1"placeholder="Ctrl + Scan to fill"><div>Description</div><input id="des"type="text"data-trimtext="1"><div>Product variants</div><input id="vPro"type="text"data-trimtext="1"placeholder="e.g. Red Blue Yellow"title="Not recommended if you need separate stock management for each variant"><div>Category</div><div class="boxParent"><svg class="icon-right caretDown"onclick="M2(M('catCode'))"><use href="/icon/tbl-ico.svg#caretdown"></use></svg><input class="has-icon-right"id="catCode"name="cat"type="text"data-noS=1><input id="catID"type="hidden"data-def=0></div><div>Supplier</div><div class="boxParent"><svg class="icon-right caretDown"onclick="M2(M('supCode'))"><use href="/icon/tbl-ico.svg#caretdown"></use></svg><input class="has-icon-right"id="supCode"name="sup"type="text"data-noS=1><input id="supID"type="hidden"data-def=0></div><div class="fitContent"><a class="delImg btn"onclick="B6(this)">X</a><img id="showImg"class="showImg"data-noS=1></div><input id="getImg"type="file"onchange="M5()"accept=".jpeg,.jpg,.png,.bmp,.tiff,.gif"data-noS=1></div><div class="group"><div>$$</div><select id="chr"onchange="N4(1)"data-def="0"><% for(let i=0; i<obj.cur.sym.length;i++){%><option value=<%=i%>><%= obj.cur.sym[i] %></option><% } %></select><div class="groupGL"><div><div>Unit</div><input id="unitN"data-def=1 onchange="Z8()"type="number"min="1"max="4"value="1"></div><div class="defaultUnit"><div>&nbsp;</div><select id="unitDef"onchange="Y('save')"data-def=0><option value="0">U.1</option></select></div></div><div class="groupGR"><div id="unitName"><div>Name</div><input id="unit"type="text"list="listunit"data-trimtext="1"></div><div id="unitScale"><div>Scale</div><input type="number"readonly value="1"tabindex="-1"></div></div><div class="groupGL"><div><div>Price</div><input id="nPrice"data-def=1 onchange="M9()"type="number"min="1"max="4"value="1"></div><div class="groupPrice"><div>&nbsp;</div><select id="priceType"onchange="N4()"data-def="man"><option value="man">$$</option><option value="sub">-x</option><option value="per">-%</option></select><div id="subPrice"></div></div></div><div class="groupGR"><div id="vPrice"><div>nPrice</div><input id="price"type="text"inputmode='numeric'oninput='D(this)'onchange='D(this,-1,N4)'></div><div id="vQty"><div>Qty</div><input type="number"readonly value="1"tabindex="-1"></div></div><div>Cost</div><input id="cost"type="text"inputmode='numeric'oninput='D(this)'onchange='D(this,-1,E4,this)'><div>Min Price</div><input id="bprice"type="text"inputmode='numeric'oninput='D(this)'onchange='D(this,-1,E4,this)'placeholder="No lower than this"><div>Stock +<input id="addStock"readonly data-def=0 tabindex="-1"></div><input id="editStock"type="number"data-noS=1 onchange="G14(this)"></div><div class="group"><div>Note</div><textarea id="note"rows="4"cols="50"onchange="Y('save')"></textarea></div></div></div><iframe id="addFrame"></iframe></div><input id="id"type="hidden"data-def=0 data-noS=1><input id="invqty"type="hidden"data-def=0 data-noS=1><input id="bilqty"type="hidden"data-def=0 data-noS=1><input id="ids"type="hidden"><datalist id="listunit"></datalist><script type="text/javascript">const keyID = ["id", "ids", "code", "bcode", "des", "vPro", "catID", "catCode", "supID", "supCode", "getImg", "chr", "cost", "bprice", "unitDef", "priceType", "note", "editStock", "addStock", "invqty", "bilqty" ]; const tblname = "pro"; const J = "pro";</script><script type="text/javascript"src="/js/auto.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/pcv.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/domtoimage.js?v=<%- obj.ver %>"></script></body></html>