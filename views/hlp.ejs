<!DOCTYPE html><html><head><meta charset="utf-8"><title>Help</title><style>body { margin: 0; } .tbl { font-weight: 600; background-color: #fcfcfc; } #boxTool { height: 45px; background: #f7f8ff; } .splitmenu { text-align: center; background-image: linear-gradient(180deg, #6997a2a6, transparent); } tr td:nth-child(1) { min-width: 150px; } #inBox div { padding: 5px; } h2 { margin: 0; text-align: center; line-height: 45px; color: white; text-shadow: 0 0 3px black; }</style></head><body><div class="screen"><div id="boxTool"><h2>Invoice Management</h2></div><div id="inBox"><div class="splitmenu">Shortcut Keys</div><div class="tbl inv">Invoice/Bill</div><div class="listkeys"><table><thead></thead><tbody><tr><td>CTRL + O</td><td>Open Invoice/Bill</td></tr><tr><td>CTRL + P</td><td>Print</td></tr><tr><td>CTRL + B</td><td>To be Print</td></tr><tr><td>CTRL + /</td><td>Last/Before Price/Cost</td></tr><tr><td>CTRL + ;</td><td>History Item/Price/Cost</td></tr><tr><td>CTRL + .</td><td>Quick Qty</td></tr><tr><td>CTRL + ,</td><td>Quick Price/Cost</td></tr><tr><td>CTRL + =</td><td>Quick Pay</td></tr><tr><td>CTRL + Delete</td><td>Delete Item</td></tr><tr><td>CTRL + I</td><td>Insert Row</td></tr><tr><td>CTRL + ArrowUp</td><td>Move Row (up)</td></tr><tr><td>CTRL + ArrowDown</td><td>Move Row (down)</td></tr></tbody></table></div><div class="tbl All">All</div><div class="listkeys"><table><thead></thead><tbody><tr><td>CTRL + S</td><td>Save Object</td></tr><tr><td>CTRL + Enter</td><td>Save and New</td></tr><tr><td>CTRL + ArrowLeft</td><td>Back Item</td></tr><tr><td>CTRL + ArrowRight</td><td>Next Item</td></tr></tbody></table></div><div class="splitmenu">Writer</div><div class="listkeys">OEUN SOKHA<br>Telegram: 070 79 75 67<br>ABA: 001 052 515 (Oeun sokha)<br>@2024, Cambodia</div></div></div><script></script></body></html>