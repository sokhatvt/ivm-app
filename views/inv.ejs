r="Location"></span><input id="locDes"type="text"placeholder="Address"></span><span id="rate"class="hiliParent hideOrderMode"></span></div></div></div><div id="addFrame"><svg id="closeFrame"class="falseBtn btn"onclick="R10()"><use href="/icon/tbl-ico.svg#close"></use></svg><iframe id="boxFrame"></iframe></div><datalist id="listnote"></datalist><input type="hidden"id="id"><input type="hidden"id="ids"><input type="hidden"id="checked"><input type="hidden"id="print"value=0></div><script type="text/javascript">const tblname = "<%= obj.tblname %>"; const J = "inv";</script><script type="text/javascript"src="/js/auto.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/inv.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/qrcode.js?v=<%- obj.ver %>"></script><script type="text/javascript"src="/js/domtoimage.js?v=<%- obj.ver %>"></script><% if(obj.tblname != "odr"){ %><%- include('./page.ejs',obj) %><script type="text/javascript"src="/js/inv-adm.js?v=<%- obj.ver %>"></script><% } %></body></html>