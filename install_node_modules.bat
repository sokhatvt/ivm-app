@echo off
title Node.js Package Auto-Installer
cls

echo ===================================================
echo       NODE.JS PACKAGE AUTO-INSTALLER
echo ===================================================
echo.

:: Check if Node.js/NPM is installed
echo [1/3] Checking Node.js environment...
node -v >nul 2>&1
if %errorlevel% neq 0 (
    echo [ERROR] Node.js or NPM is not installed!
    echo Please install Node.js from https://nodejs.org/ first.
    echo.
    pause
    exit /b
)
echo [SUCCESS] Node.js is ready.
echo.

:: Check if package.json exists
echo [2/3] Checking for package.json...
if not exist "package.json" (
    echo [WARNING] package.json not found in this directory.
    echo [INFO] Initializing a new Node.js project...
    call npm init -y
    echo [SUCCESS] package.json created.
) else (
    echo [SUCCESS] package.json found.
)
echo.

:: Install libraries
echo [3/3] Installing Node.js packages...
echo ---------------------------------------------------
echo.

call npm install

echo.
echo ---------------------------------------------------
echo [SUCCESS] All packages have been installed successfully!
echo ===================================================
echo.
pause